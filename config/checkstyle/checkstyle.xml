<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Minimal Checkstyle configuration for spring-ai-hybrid-retriever.

  Formatting is handled entirely by Spotless (Google Java Format).
  This file only enforces rules that Spotless does not cover.
-->
<module name="Checker">

    <!--
      Test methods intentionally use the BDD naming pattern:
        methodUnderTest_scenario_expectedOutcome
      Suppress MethodName on *Test.java files only so the rule still
      catches non-BDD names in production code.
    -->
    <module name="SuppressionSingleFilter">
        <property name="files" value=".*Test\.java"/>
        <property name="checks" value="MethodName"/>
    </module>

    <module name="TreeWalker">

        <!-- Imports -->
        <module name="AvoidStarImport"/>
        <module name="UnusedImports"/>

        <!-- Structure -->
        <module name="OneTopLevelClass"/>

        <!-- Naming conventions -->
        <module name="TypeName"/>
        <module name="MethodName"/>
        <module name="ConstantName"/>

    </module>

</module>
